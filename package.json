{
  "name": "@ghettoddos/oxfmt-config",
  "version": "0.0.1",
  "description": "ghettoDdOS's Oxfmt config",
  "keywords": [
    "oxfmt-config"
  ],
  "homepage": "https://github.com/ghettoDdOS/oxfmt-config",
  "bugs": {
    "url": "https://github.com/ghettoDdOS/oxfmt-config/issues"
  },
  "license": "MIT",
  "author": "ghettoDdOS <pen.egor2002@gaml.com> (https://github.com/ghettoDdOS/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghettoDdOS/oxfmt-config.git"
  },
  "funding": "https://github.com/sponsors/ghettoDdOS",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint --type-check",
    "lint:fix": "oxlint --type-check --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepack": "nr build",
    "release": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@ghettoddos/oxlint-config": "^0.0.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "oxfmt": "^0.43.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.33.0"
}
